#!/usr/bin/env bash
set -euo pipefail
BUN_BIN="${BUN:-}"
if [ -z "$BUN_BIN" ]; then
  if command -v bun >/dev/null 2>&1; then
    BUN_BIN="$(command -v bun)"
  else
    BUN_BIN="$HOME/.bun/bin/bun"
  fi
fi
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
for arg in "$@"; do
  if [ "$arg" = "--no-tui" ]; then
    exec "$BUN_BIN" "$ROOT/src-ts/cli.ts" "$@"
  fi
done
exec "$BUN_BIN" "$ROOT/src-ts/opentui.ts" "$@"
